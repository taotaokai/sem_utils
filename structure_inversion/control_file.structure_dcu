#====== line search

# To account for imbalanced sensitvity between different parameter classes,
# we can seperate the search direction(dm) into two parts(dm1, dm2), for example dvp and dvs:
# and we define the new search direction is linear combination of dm1 and dm2:
#   1) dm = a1 * dm1 + a2 * dm2
# From forward modelling of models perturbed by dm1 and dm2, we can write:
#   2) du1 := u(m+dm1) - u(m) ~ dm1 * grad(u)
#   3) du2 := u(m+dm2) - u(m) ~ dm2 * grad(u)
# Synthetics from any linear combination of dm1 and dm2 can be approximated by:
#   4) u(m+dm) ~ u(m) + dm * grad(u) = u(m) + a1*dm1 * grad(u) + a2*dm2 * grad(u) ~ u(m) + a1*du1 + a2*du2
# To maximize the objective function(Chi) we grid search through a1 and a2: 
#   5) argmax(Chi[u(m)+ a1*du1 + a2*du2]) for a1,a2 in some seach ranges
# The optimal a1, a2 would give the updated model as m + a1*dm1 + a2*dm2

# perturbations along different parameter groups
SEM_perturb_group_names=("dm")  # only one group
SEM_perturb_model_tag_groups=("alpha,beta,phi,xi,eta,rho")
SEM_perturb_dmodel_tag_groups=("alpha_dmodel,beta_dmodel,phi_dmodel,xi_dmodel,eta_dmodel,rho_dmodel")
# steps along each perturbation group (min,max,ngrids) as in numpy.linspace(min,max,ngrids)
